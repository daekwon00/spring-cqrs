<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.study.springcqrs.admin.dashboard.mapper.query.AdminDashboardQueryMapper">

    <select id="selectTotalUsers" resultType="long">
        SELECT COUNT(*) FROM tb_user
    </select>

    <select id="selectTodayRegistered" resultType="long">
        SELECT COUNT(*)
        FROM tb_user
        WHERE created_date >= CURRENT_DATE
    </select>

    <select id="selectActiveBoards" resultType="long">
        SELECT COUNT(*)
        FROM tb_board
        WHERE use_yn = true
    </select>

    <select id="selectTodayPosts" resultType="long">
        SELECT COUNT(*)
        FROM tb_post
        WHERE created_date >= CURRENT_DATE
    </select>

    <select id="selectRecentUsers" resultType="map">
        SELECT user_id, user_name, email, created_date
        FROM tb_user
        ORDER BY created_date DESC
        LIMIT 5
    </select>

</mapper>
