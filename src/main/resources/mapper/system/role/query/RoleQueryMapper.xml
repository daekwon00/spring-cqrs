<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.study.springcqrs.system.role.mapper.query.RoleQueryMapper">

    <select id="selectRoleList" resultType="kr.or.study.springcqrs.system.role.dto.query.response.RoleResponse">
        SELECT role_id AS id, role_name AS name, description
        FROM tb_role
        WHERE use_yn = true
        ORDER BY role_level
    </select>

    <select id="selectRoleById" resultType="kr.or.study.springcqrs.system.role.dto.query.response.RoleResponse">
        SELECT role_id AS id, role_name AS name, description
        FROM tb_role
        WHERE role_id = #{roleId}
    </select>

</mapper>
