<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.study.springcqrs.system.menurole.mapper.query.MenuRoleQueryMapper">

    <select id="selectAllMenuRoles" resultType="kr.or.study.springcqrs.system.menurole.dto.query.response.MenuRoleResponse">
        SELECT menu_id AS menuId, role_id AS roleId
        FROM tb_role_menu
        ORDER BY role_id, menu_id
    </select>

</mapper>
